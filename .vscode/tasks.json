{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flutter: Run Debug (Hot Reload Enabled)",
      "type": "shell",
      "command": "flutter",
      "args": [
        "run",
        "--verbose"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": false,
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Flutter: Run on Chrome",
      "type": "shell",
      "command": "flutter",
      "args": [
        "run",
        "-d",
        "chrome"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build"
      }
    },
    {
      "label": "Flutter: Clean & Run",
      "type": "shell",
      "command": "flutter",
      "args": [
        "clean"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build"
      }
    }
  ]
}
